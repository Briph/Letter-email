# ── Letter Server Environment ──────────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the server.

# Port the API listens on
PORT=3001

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_STRING

# Credential encryption key — used to encrypt stored IMAP/SMTP passwords
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_SECRET=CHANGE_ME_TO_A_32_CHAR_RANDOM_STRING

# Token lifetimes
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Path to SQLite database file (created automatically)
DB_PATH=./data/letter.db

# Allowed origins for CORS (comma-separated)
# Add your production domain and Electron app origin
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: set to "production" to disable request logging
NODE_ENV=development

# ── OAuth2 (Gmail + Outlook) ──────────────────────────────────────────────────
# The redirect URI must match exactly what you register in Google / Microsoft.
# For local dev, http://localhost:3001/api/oauth/callback works for both.
OAUTH_REDIRECT_URI=http://localhost:3001/api/oauth/callback

# Google OAuth2 — create a project at console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID (Desktop app)
# Enable the Gmail API and add the redirect URI above to "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 — register an app at portal.azure.com → Azure Active Directory → App registrations
# Add a Mobile/Desktop redirect URI: http://localhost:3001/api/oauth/callback
# Under API permissions add: IMAP.AccessAsUser.All and SMTP.Send (Office 365 Exchange Online)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
